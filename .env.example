# Required for Payload CMS auth and encryption. Generate with: openssl rand -base64 32
PAYLOAD_SECRET=

# Required for Payload's Postgres adapter.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auto_blogger

# Public site URL used by CMS previews, CORS, SEO URLs, RSS, and sitemap generation.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional provider-based AI key. Local Ollama is intentionally not configured.
OPENAI_API_KEY=

# Optional Redis URL for BullMQ workers when background generation is added.
REDIS_URL=redis://localhost:6379
